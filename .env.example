# Environment variables for this project
# Copy this file to .env.local for local development or configure these values in your deploy provider.
# Never commit real production secrets.

# Frontend URL used by auth callbacks and links.
# Required: yes
VITE_PUBLIC_APP_URL=http://localhost:5173

# Backend API base URL.
# Required: yes
VITE_API_BASE_URL=https://api.example.com

# Auth provider name or mode.
# Required: no
VITE_AUTH_PROVIDER=credentials

# Database connection string for backend services.
# Required: yes | Secret: yes
DATABASE_URL=postgresql://user:password@host:5432/database

# Token signing secret for backend auth.
# Required: yes | Secret: yes
JWT_SECRET=replace-with-a-long-random-secret

# Payment provider secret key when billing is enabled.
# Required: no | Secret: yes
STRIPE_SECRET_KEY=sk_test_replace_me

# Email service API key for transactional email.
# Required: no | Secret: yes
RESEND_API_KEY=re_replace_me

# Optional AI service key used by generated backend features.
# Required: no | Secret: yes
OPENAI_API_KEY=sk-replace-me

# Optional Gemini key used by generated backend features.
# Required: no | Secret: yes
GEMINI_API_KEY=replace-me
